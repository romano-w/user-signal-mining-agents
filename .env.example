USM_ENVIRONMENT=development
GEMINI_API_KEY=your-gemini-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
OPENROUTER_API_KEY=your-openrouter-api-key-here
HF_TOKEN=your-hf-token-here
USM_LLM_PROVIDER=gemini
USM_LLM_MODEL=gemini-2.5-flash
USM_LLM_TEMPERATURE=0.3
USM_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
USM_FOUNDER_PROMPTS_PATH=founder_prompts/restaurants.json
USM_YELP_DOWNLOAD_URL=https://business.yelp.com/external-assets/files/Yelp-JSON.zip
USM_YELP_DATASET_DIR=data/raw/Yelp-JSON
USM_YELP_DOWNLOAD_ZIP_PATH=data/raw/Yelp-JSON/Yelp-JSON.zip
USM_YELP_TAR_PATH=data/raw/Yelp-JSON/yelp_dataset.tar
USM_YELP_BUSINESSES_PATH=data/raw/Yelp-JSON/yelp_academic_dataset_business.json
USM_YELP_REVIEWS_PATH=data/raw/Yelp-JSON/yelp_academic_dataset_review.json
USM_WORKING_SUBSET_PATH=data/processed/restaurant_reviews.jsonl
USM_INDEX_DIR=artifacts/index
USM_RUN_ARTIFACTS_DIR=artifacts/runs
USM_RESTAURANT_REVIEW_LIMIT=75000
USM_MAX_REVIEWS_PER_BUSINESS=200
USM_MIN_REVIEW_CHARACTERS=60
USM_CHUNK_SENTENCE_WINDOW=2
USM_CHUNK_SENTENCE_STRIDE=1
USM_MAX_CHUNKS_PER_REVIEW=3
USM_RETRIEVAL_TOP_K=50
USM_SYNTHESIS_EVIDENCE_K=15
USM_EMBEDDING_BATCH_SIZE=128
